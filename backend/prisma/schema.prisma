// Canonical Phase 0 schema snapshot. This file is the human-reviewable
// copy of `backend/prisma/schema.prisma`. The two MUST stay in sync;
// the schema-drift CI gate (research R11) verifies the database
// matches `backend/prisma/schema.prisma`, and code review verifies
// `backend/prisma/schema.prisma` matches this file.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = []
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ----------------------------------------------------------------------------
// Enums
// ----------------------------------------------------------------------------

enum Role {
  ADMIN
  CUSTOMER
  CHEF
  DRIVER // reserved for v2 per Constitution Principle VII
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  READY
  ON_THE_WAY
  DELIVERED
  CANCELLED
}

enum PaymentMethod {
  CASH
  VISA     // reserved for v2
  INSTAPAY // reserved for v2
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum DiscountUnit {
  FIXED
  PERCENT
}

enum NotificationType {
  ORDER_PLACED
  ORDER_CONFIRMED
  ORDER_PREPARING
  ORDER_READY
  ORDER_ON_THE_WAY
  ORDER_DELIVERED
  ORDER_CANCELLED
  ORDER_REVIEW
  CHEF_VERIFIED
  CHEF_REJECTED
  SYSTEM
}

// ----------------------------------------------------------------------------
// Models — soft-delete entities (constitution-listed)
// ----------------------------------------------------------------------------

model User {
  id                 String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  phone              String              @unique
  email              String?             @unique
  fullName           String
  birthdate          DateTime?           @db.Date
  passwordHash       String
  role               Role                @default(CUSTOMER)
  phoneVerified      Boolean             @default(false)
  fcmToken           String?
  isTest             Boolean             @default(false)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  deletedAt          DateTime?

  addresses          UserAddress[]
  chef               Chef?
  cart               Cart?
  orders             Order[]
  reviews            UserReview[]
  favorites          Favorite[]
  notifications      Notification[]
  invalidatedTokens  InvalidatedToken[]
}

model UserAddress {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String    @db.Uuid
  label       String
  streetName  String
  building    String?
  floor       String?
  apartment   String?
  latitude    Decimal   @db.Decimal(10, 7)
  longitude   Decimal   @db.Decimal(10, 7)
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  user        User      @relation(fields: [userId], references: [id])
  orders      Order[]

  @@index([userId])
}

model Chef {
  id              String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String       @unique @db.Uuid
  chefName        String
  bio             String?
  latitude        Decimal      @db.Decimal(10, 7)
  longitude       Decimal      @db.Decimal(10, 7)
  isVerified      Boolean      @default(false)
  isOpen          Boolean      @default(false)
  ratings         Decimal      @default(0) @db.Decimal(3, 2)
  totalReviews    Int          @default(0)
  minOrderPrice   Decimal      @db.Decimal(10, 2)
  logo            String
  banner          String
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  deletedAt       DateTime?

  user            User         @relation(fields: [userId], references: [id])
  menus           Menu[]
  orders          Order[]
  reviews         UserReview[]
  favorites       Favorite[]
}

model Category {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name          Json
  icon          String?
  displayOrder  Int       @default(0)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  menus         Menu[]
}

model Menu {
  id                String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  chefId            String              @db.Uuid
  categoryId        String              @db.Uuid
  name              Json
  displayOrder      Int                 @default(0)
  availableAllDays  Boolean             @default(false)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  deletedAt         DateTime?

  chef              Chef                @relation(fields: [chefId], references: [id])
  category          Category            @relation(fields: [categoryId], references: [id])
  items             Item[]
  availability      MenuAvailability[]

  @@index([chefId])
}

model Item {
  id              String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  menuId          String       @db.Uuid
  name            Json
  description     Json
  price           Decimal      @db.Decimal(10, 2)
  discountValue   Decimal      @default(0) @db.Decimal(10, 2)
  discountUnit    DiscountUnit @default(FIXED)
  quantity        Int
  images          String[]
  displayOrder    Int          @default(0)
  isActive        Boolean      @default(true)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  deletedAt       DateTime?

  menu            Menu         @relation(fields: [menuId], references: [id])
  cartItems       CartItem[]
  orderItems      OrderItem[]

  @@index([menuId])
}

model Order {
  id                       String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId                   String         @db.Uuid
  chefId                   String         @db.Uuid
  addressId                String         @db.Uuid
  scheduledDate            DateTime?      @db.Date
  subtotal                 Decimal        @db.Decimal(10, 2)
  subtotalAfterDiscount    Decimal        @db.Decimal(10, 2)
  deliveryFee              Decimal        @db.Decimal(10, 2)
  serviceFee               Decimal        @db.Decimal(10, 2)
  total                    Decimal        @db.Decimal(10, 2)
  notes                    String?
  cancelledReason          String?
  status                   OrderStatus    @default(PENDING)
  createdAt                DateTime       @default(now())
  updatedAt                DateTime       @updatedAt
  deletedAt                DateTime?

  user                     User           @relation(fields: [userId], references: [id])
  chef                     Chef           @relation(fields: [chefId], references: [id])
  address                  UserAddress    @relation(fields: [addressId], references: [id])
  items                    OrderItem[]
  transaction              Transaction?
  review                   UserReview?

  @@index([userId])
  @@index([chefId])
  @@index([status])
}

model UserReview {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String    @db.Uuid
  chefId      String    @db.Uuid
  orderId     String    @unique @db.Uuid
  rating      Int
  notes       String?
  images      String[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  user        User      @relation(fields: [userId], references: [id])
  chef        Chef      @relation(fields: [chefId], references: [id])
  order       Order     @relation(fields: [orderId], references: [id])

  @@index([userId])
  @@index([chefId])
}

model Transaction {
  id                String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId           String             @unique @db.Uuid
  paymentMethod     PaymentMethod      @default(CASH)
  amount            Decimal            @db.Decimal(10, 2)
  cardAmount        Decimal?           @db.Decimal(10, 2)
  status            TransactionStatus  @default(PENDING)
  gatewayReference  String?
  paidAt            DateTime?
  failureReason     String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  deletedAt         DateTime?

  order             Order              @relation(fields: [orderId], references: [id])
}

// ----------------------------------------------------------------------------
// Models — hard-delete entities (operational / join / snapshot)
// ----------------------------------------------------------------------------

model MenuAvailability {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  menuId     String   @db.Uuid
  dayOfWeek  Int
  createdAt  DateTime @default(now())

  menu       Menu     @relation(fields: [menuId], references: [id])

  @@unique([menuId, dayOfWeek])
}

model Cart {
  id         String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String     @unique @db.Uuid
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  user       User       @relation(fields: [userId], references: [id])
  items      CartItem[]
}

model CartItem {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cartId     String   @db.Uuid
  itemId     String   @db.Uuid
  quantity   Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  cart       Cart     @relation(fields: [cartId], references: [id])
  item       Item     @relation(fields: [itemId], references: [id])
}

model OrderItem {
  id                    String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId               String   @db.Uuid
  itemId                String   @db.Uuid
  quantity              Int
  price                 Decimal  @db.Decimal(10, 2)
  priceBeforeDiscount   Decimal  @db.Decimal(10, 2)
  nameSnapshot          Json
  createdAt             DateTime @default(now())

  order                 Order    @relation(fields: [orderId], references: [id])
  item                  Item     @relation(fields: [itemId], references: [id])
}

model Favorite {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String   @db.Uuid
  chefId     String   @db.Uuid
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id])
  chef       Chef     @relation(fields: [chefId], references: [id])

  @@unique([userId, chefId])
}

model Notification {
  id         String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String           @db.Uuid
  type       NotificationType
  title      Json
  body       Json
  data       Json?
  readAt     DateTime?
  createdAt  DateTime         @default(now())

  user       User             @relation(fields: [userId], references: [id])

  @@index([userId, readAt])
}

model InvalidatedToken {
  jti        String   @id
  userId     String   @db.Uuid
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id])

  @@index([expiresAt])
}
