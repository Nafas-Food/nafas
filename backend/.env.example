# Database (per-contributor Supabase project — see README)
DATABASE_URL="postgresql://postgres:PASSWORD@db.PROJECT.supabase.co:5432/postgres"

# Supabase Storage (used from Phase 3)
SUPABASE_URL="https://PROJECT.supabase.co"
SUPABASE_SERVICE_KEY="REPLACE_WITH_SERVICE_ROLE_KEY"

# Default chef placeholders (uploaded per-contributor; see quickstart Step 5)
DEFAULT_CHEF_LOGO_URL=""
DEFAULT_CHEF_BANNER_URL=""

# JWT (RS256) — base64-encoded PEMs (used from Phase 1)
# Generate with:
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem
#   base64 -w 0 private.pem  (Linux/WSL) or [Convert]::ToBase64String([IO.File]::ReadAllBytes("private.pem"))  (PowerShell)
JWT_PRIVATE_KEY=""
JWT_PUBLIC_KEY=""

# Phase 1 — JWT TTL & Issuer
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=2592000
JWT_ISSUER=nafas

# Phase 1 — Twilio Verify (research R1)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=

# Phase 3 — Firebase Cloud Messaging (push notifications for chef state transitions)
# Procure via Firebase Console → Project Settings → Service accounts → Generate
# new private key. Use EITHER the inline JSON (preferred for CI) OR the file
# path; the FcmService prefers KEY over KEY_PATH when both are set.
FIREBASE_SERVICE_ACCOUNT_KEY=
FIREBASE_SERVICE_ACCOUNT_KEY_PATH=

# Email OTP (optional channel — saves SMS cost when customer provides email).
# Leave EMAIL_OTP_LIVE unset in development: the LoggingEmailClient prints the
# code to stdout so you don't burn Resend's free quota. Set to "true" (or run
# with NODE_ENV=production) to wire the real Resend SDK; RESEND_API_KEY and
# RESEND_FROM_EMAIL must then be set.
EMAIL_OTP_LIVE=
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@nafas.app
OTP_EMAIL_TTL_SECONDS=600
OTP_EMAIL_MAX_ATTEMPTS=5

# CORS — comma-separated list of origins allowed to send credentialed requests.
# For physical-device testing, add your machine's LAN IP (e.g. http://192.168.1.2:3000).
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Backend port
BACKEND_PORT=3000

# Service version (read into health endpoint)
npm_package_version=0.1.0
